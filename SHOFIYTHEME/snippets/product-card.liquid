<a href="{{ product.url | within: collection }}" class="product-card">

  {%- comment -%} Image Media {%- endcomment -%}
  <div class="product-card__media">

    {%- comment -%} Badges {%- endcomment -%}
    <div class="product-card__badges">
      {% if product.compare_at_price > product.price %}
        {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
        <span class="badge badge-sale">-{{ discount }}%</span>
      {% endif %}
      {% if product.tags contains 'new' %}
        <span class="badge badge-new">New</span>
      {% endif %}
      {% if product.tags contains 'hot' %}
        <span class="badge badge-hot">🔥 Hot</span>
      {% endif %}
    </div>

    {%- comment -%} Primary image {%- endcomment -%}
    {% if product.featured_image != blank %}
      {{ product.featured_image | image_url: width: 600 | image_tag:
        class: 'product-card__img product-card__img--primary',
        loading: 'lazy',
        alt: product.featured_image.alt | default: product.title
      }}
      {%- comment -%} Hover image {%- endcomment -%}
      {% if product.images[1] != blank %}
        {{ product.images[1] | image_url: width: 600 | image_tag:
          class: 'product-card__img product-card__img--hover',
          loading: 'lazy',
          alt: product.title
        }}
      {% endif %}
    {% else %}
      <div class="product-card__img product-card__img--primary" style="background: var(--clr-surface-2); display:flex; align-items:center; justify-content:center; height:100%;">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="var(--clr-muted-2)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9l4-4 4 4 4-5 4 5"/></svg>
      </div>
    {% endif %}

    {%- comment -%} Quick Add overlay {%- endcomment -%}
    <div class="product-card__quick-view">
      {% if product.available %}
        Quick Add — {{ product.price | money }}
      {% else %}
        Sold Out
      {% endif %}
    </div>

    {%- comment -%} Action buttons {%- endcomment -%}
    <div class="product-card__actions">
      <button class="product-card__action-btn" aria-label="Add to wishlist">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
      </button>
    </div>

  </div>

  {%- comment -%} Product Info {%- endcomment -%}
  <div class="product-card__body">
    <div class="product-card__title">{{ product.title }}</div>

    <div class='jdgm-widget jdgm-preview-badge' data-id='{{ product.id }}'>
      {{ product.metafields.judgeme.badge }}
    </div>

    <div class="product-card__price-row">
      {% render 'price', product: product %}
    </div>

    <button
      class="btn btn-primary btn-sm btn-full"
      style="margin-top: auto;"
      {% if product.available %}
        onclick="event.preventDefault(); window.quickAdd && window.quickAdd('{{ product.selected_or_first_available_variant.id }}', this);"
      {% else %}
        disabled style="opacity:0.5; cursor:not-allowed;"
      {% endif %}
    >
      {% if product.available %}
        {% render 'icon-cart' %} Add to Cart
      {% else %}
        Sold Out
      {% endif %}
    </button>
  </div>

</a>
