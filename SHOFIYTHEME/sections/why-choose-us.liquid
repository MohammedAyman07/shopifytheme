<div class="why-choose-us section-gap-lg">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">{{ section.settings.eyebrow }}</div>
      <h2 class="section-title">{{ section.settings.title }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="why-choose-grid">
      {% for block in section.blocks %}
        <div class="why-card reveal reveal-delay-{{ forloop.index | modulo: 4 }}" {{ block.shopify_attributes }}>
          <div class="why-card__icon">
            {% case block.settings.icon %}
              {% when 'globe' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
              {% when 'shield' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              {% when 'star' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
              {% when 'truck' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              {% when 'refresh' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="1 4 1 10 7 10"></polyline><polyline points="23 20 23 14 17 14"></polyline><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"></path></svg>
              {% when 'headphones' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg>
            {% endcase %}
          </div>
          <h3 class="why-card__title">{{ block.settings.title }}</h3>
          <p class="why-card__text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Promise"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why Choose Daily Scroll"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "We pride ourselves on delivering the ultimate premium shopping experience."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "globe", "label": "Globe" },
            { "value": "shield", "label": "Shield" },
            { "value": "star", "label": "Star" },
            { "value": "truck", "label": "Truck" },
            { "value": "refresh", "label": "Refresh" },
            { "value": "headphones", "label": "Headphones" }
          ],
          "default": "star"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Premium Quality"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Curated selection of high-end products."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us Grid",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "title": "Worldwide Delivery", "text": "Fast and secure shipping globally." } },
        { "type": "feature", "settings": { "icon": "shield", "title": "Secure Payments", "text": "100% encrypted and safe checkout." } },
        { "type": "feature", "settings": { "icon": "star", "title": "Premium Products", "text": "Curated selection of high-end products." } },
        { "type": "feature", "settings": { "icon": "refresh", "title": "Easy Returns", "text": "30-day hassle-free return policy." } },
        { "type": "feature", "settings": { "icon": "headphones", "title": "24/7 Support", "text": "Our team is always here to help you." } },
        { "type": "feature", "settings": { "icon": "globe", "title": "Global Community", "text": "Join thousands of happy customers." } }
      ]
    }
  ]
}
{% endschema %}
