<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-col">
        <div class="footer-brand__logo">Daily <span>Scroll</span></div>
        <p class="footer-brand__desc">Carefully curated innovative products designed to simplify your lifestyle with secure shopping and worldwide delivery.</p>
        
        <div class="footer-social">
          {% if settings.social_instagram_link != blank %}
            <a href="{{ settings.social_instagram_link }}" class="footer-social-link" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok_link != blank %}
            <a href="{{ settings.social_tiktok_link }}" class="footer-social-link" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_facebook_link != blank %}
            <a href="{{ settings.social_facebook_link }}" class="footer-social-link" target="_blank" rel="noopener">
               <svg viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_twitter_link != blank %}
             <a href="{{ settings.social_twitter_link }}" class="footer-social-link" target="_blank" rel="noopener">
               <svg viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
             </a>
          {% endif %}
        </div>
      </div>
      
      {% for block in section.blocks %}
        <div class="footer-col" {{ block.shopify_attributes }}>
          <div class="footer-col-title">{{ block.settings.title }}</div>
          {% if block.type == 'link_list' %}
            <div class="footer-links">
              {% for link in linklists[block.settings.menu].links %}
                <a href="{{ link.url }}" class="footer-link">{{ link.title }}</a>
              {% endfor %}
            </div>
          {% elsif block.type == 'text' %}
            <div class="footer-text" style="color: var(--clr-muted); font-size: var(--text-sm); line-height: 1.6;">
              {{ block.settings.text }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    
    <div class="footer-bottom">
      <div class="footer-copyright-group">
        <div class="footer-copyright">
          &copy; {{ 'now' | date: "%Y" }} Daily Scroll. All Rights Reserved.
        </div>
        <div class="footer-legal-links" style="display: flex; gap: var(--space-4); margin-top: var(--space-2); font-size: var(--text-xs); color: var(--clr-muted);">
          <a href="/policies/privacy-policy" style="transition: color 0.2s; cursor: pointer;" onmouseover="this.style.color='var(--clr-gold)'" onmouseout="this.style.color='var(--clr-muted)'">Privacy Policy</a>
          <a href="/policies/terms-of-service" style="transition: color 0.2s; cursor: pointer;" onmouseover="this.style.color='var(--clr-gold)'" onmouseout="this.style.color='var(--clr-muted)'">Terms & Conditions</a>
          <a href="/policies/refund-policy" style="transition: color 0.2s; cursor: pointer;" onmouseover="this.style.color='var(--clr-gold)'" onmouseout="this.style.color='var(--clr-muted)'">Refund Policy</a>
        </div>
      </div>
      
      <div class="footer-payment-icons">
        <div class="payment-icon">Visa</div>
        <div class="payment-icon">Mastercard</div>
        <div class="payment-icon">Amex</div>
        <div class="payment-icon">PayPal</div>
        <div class="payment-icon">Apple Pay</div>
      </div>
      
      <div class="footer-trust">
        <div class="footer-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0110 0v4"></path></svg>
          Secure Checkout
        </div>
        <div class="footer-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          SSL Encrypted
        </div>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 3,
  "settings": [],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Contact us"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share contact info, store details, or brand content with your customers.</p>"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "title": "Shop",
          "menu": "main-menu"
        }
      },
      {
        "type": "text",
        "settings": {
          "title": "Support",
          "text": "<p><a href=\\\"mailto:dailyscrollstore@gmail.com\\\">dailyscrollstore@gmail.com</a></p>"
        }
      }
    ]
  }
}
{% endschema %}
