<div class="about-hero">
  <div class="container container--narrow text-center">
    <div class="about-hero__content reveal">
      <div class="section-label" style="justify-content: center; margin-bottom: var(--space-6);">{{ section.settings.eyebrow }}</div>
      <h1 class="page-hero__title" style="color: var(--clr-white);">{{ section.settings.title }}</h1>
      <p class="page-hero__subtitle" style="color: rgba(255,255,255,0.7); max-width: 600px; margin-inline: auto;">{{ section.settings.subtitle }}</p>
    </div>
  </div>
</div>

<div class="section-gap-lg">
  <div class="container">
    <div class="about-story">
      <div class="about-story__content reveal reveal-delay-1">
        <h2 class="section-title" style="font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl)); margin-bottom: var(--space-6);">{{ section.settings.story_title }}</h2>
        <div class="text-lg text-muted" style="line-height: 1.8;">
          {{ section.settings.story_text }}
        </div>
        
        <div style="display: flex; gap: var(--space-8); margin-top: var(--space-8);">
          <div>
            <div style="font-family: var(--font-display); font-size: var(--text-4xl); font-weight: 800; color: var(--clr-gold);">10K+</div>
            <div style="font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--clr-muted);">Happy Customers</div>
          </div>
          <div>
            <div style="font-family: var(--font-display); font-size: var(--text-4xl); font-weight: 800; color: var(--clr-gold);">50+</div>
            <div style="font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--clr-muted);">Countries Shipped</div>
          </div>
        </div>
      </div>
      
      <div class="about-story__img reveal reveal-delay-2">
        {% if section.settings.story_image != blank %}
          {{ section.settings.story_image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {% else %}
          <img src="https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-lifestyle-1.png" alt="Our story">
        {% endif %}
      </div>
    </div>
  </div>
</div>

<div class="section-gap" style="background: var(--clr-surface);">
  <div class="container container--narrow">
    <div class="section-header reveal">
      <h2 class="section-title">Our Journey</h2>
    </div>
    
    <div class="timeline reveal reveal-delay-1">
      {% for block in section.blocks %}
        <div class="timeline-item" {{ block.shopify_attributes }}>
          <div class="timeline-item__year">{{ block.settings.year }}</div>
          <h3 class="timeline-item__title">{{ block.settings.title }}</h3>
          <p class="timeline-item__text">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Template",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Hero Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Hero Title",
      "default": "Redefining Premium Lifestyle"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Hero Subtitle",
      "default": "We believe that everyday products should not only be highly functional, but also beautifully designed."
    },
    {
      "type": "text",
      "id": "story_title",
      "label": "Story Title",
      "default": "Designed for modern living."
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Story Text",
      "default": "<p>Founded with a passion for excellence, Daily Scroll began with a simple idea: to curate and create products that elevate your everyday routine.</p><p>We partner with the world's finest manufacturers to ensure every item meets our strict quality standards. From materials to packaging, we focus on every detail so you don't have to.</p>"
    },
    {
      "type": "image_picker",
      "id": "story_image",
      "label": "Story Image"
    }
  ],
  "blocks": [
    {
      "type": "timeline",
      "name": "Timeline Item",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2020"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "The Beginning"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Started as a small curation of our favorite products."
        }
      ]
    }
  ]
}
{% endschema %}
