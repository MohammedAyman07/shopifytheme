<div style="text-align: center; padding: 4rem 1rem;">
  <h1>Here's your gift card!</h1>
  <div style="font-size: 2rem; margin: 2rem 0;">{{ gift_card.code | format_code }}</div>
  <p>Balance: {{ gift_card.balance | money }}</p>
  <a href="{{ shop.url }}" class="btn btn-primary" target="_blank" rel="noopener">Start Shopping</a>
</div>
{% schema %}
{
  "name": "Gift Card",
  "settings": []
}
{% endschema %}
