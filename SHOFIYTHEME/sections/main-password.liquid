<div class="page-hero" style="min-height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center;">
  <div class="container">
    <div style="font-size: 3rem; margin-bottom: var(--space-4);">🔒</div>
    <h1 class="page-hero__title">Coming Soon</h1>
    <p class="page-hero__subtitle" style="margin-bottom: var(--space-8);">Our store is opening soon. Enter password to access.</p>
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <div style="display: flex; gap: var(--space-2); max-width: 400px; margin: 0 auto;">
        <input type="password" name="password" id="Password" placeholder="Enter password" style="flex: 1; padding: 1rem; border: 1px solid var(--clr-border); border-radius: var(--radius-sm);">
        <button type="submit" name="commit" class="btn btn-primary">Enter</button>
      </div>
    {% endform %}
  </div>
</div>
{% schema %}
{
  "name": "Password Page",
  "settings": []
}
{% endschema %}
