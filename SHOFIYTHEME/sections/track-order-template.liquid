<div class="page-hero">
  <div class="container">
    <h1 class="page-hero__title">{{ page.title }}</h1>
    <div class="page-hero__subtitle">{{ section.settings.subtitle }}</div>
  </div>
</div>

<div class="section-gap container">
  <div class="track-form reveal">
    <div style="font-size: 3rem; margin-bottom: var(--space-4);">📦</div>
    <h2 style="font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 800; margin-bottom: var(--space-2);">Track Your Package</h2>
    <p style="color: var(--clr-muted); margin-bottom: var(--space-6);">Enter your tracking number below to see the current status of your shipment.</p>
    
    <form id="TrackingForm" onsubmit="event.preventDefault(); document.getElementById('TrackingResult').style.display='block';">
      <div style="display: flex; gap: var(--space-2);">
        <input type="text" placeholder="Enter tracking number (e.g., YT123456789)" style="flex: 1; padding: 1rem 1.5rem; border: 1.5px solid var(--clr-border); border-radius: var(--radius-full); font-size: var(--text-base); outline: none;" required>
        <button type="submit" class="btn btn-primary">Track</button>
      </div>
    </form>
  </div>

  <div id="TrackingResult" class="tracking-result reveal" style="display: none; max-width: 800px; margin-inline: auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-8); padding-bottom: var(--space-4); border-bottom: 1px solid var(--clr-border);">
      <div>
        <div style="font-size: var(--text-xs); color: var(--clr-muted); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 4px;">Tracking Number</div>
        <div style="font-size: var(--text-xl); font-weight: 700; font-family: var(--font-display);">YT123456789</div>
      </div>
      <div style="text-align: right;">
        <div style="font-size: var(--text-xs); color: var(--clr-muted); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 4px;">Status</div>
        <div style="display: inline-flex; align-items: center; gap: 6px; background: rgba(201,168,76,0.1); color: var(--clr-gold-dark); padding: 4px 12px; border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 700;">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          In Transit
        </div>
      </div>
    </div>

    <div class="tracking-steps">
      <div class="tracking-step done">
        <div class="tracking-step__dot"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
        <div class="tracking-step__label">Order Placed</div>
        <div class="tracking-step__date">Oct 10, 09:41 AM</div>
      </div>
      <div class="tracking-step done">
        <div class="tracking-step__dot"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></div>
        <div class="tracking-step__label">Processed</div>
        <div class="tracking-step__date">Oct 11, 02:15 PM</div>
      </div>
      <div class="tracking-step current">
        <div class="tracking-step__dot">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
        </div>
        <div class="tracking-step__label">In Transit</div>
        <div class="tracking-step__date">Oct 12, 08:30 AM</div>
      </div>
      <div class="tracking-step">
        <div class="tracking-step__dot"></div>
        <div class="tracking-step__label">Delivered</div>
        <div class="tracking-step__date">Pending</div>
      </div>
    </div>
    
    <div style="margin-top: var(--space-8); padding: var(--space-4); background: rgba(0,0,0,0.03); border-radius: var(--radius-lg); font-size: var(--text-sm); color: var(--clr-muted);">
      <div style="font-weight: 600; color: var(--clr-black); margin-bottom: 4px;">Latest Update:</div>
      Package has left the distribution center and is en route to destination country.
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Track Order Template",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Track the status of your shipment."
    }
  ]
}
{% endschema %}
