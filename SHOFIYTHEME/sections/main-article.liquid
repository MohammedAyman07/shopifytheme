<div class="container container--narrow section-gap-lg">
  <div style="text-align: center; margin-bottom: var(--space-8);">
    <div style="font-size: var(--text-sm); color: var(--clr-muted); margin-bottom: var(--space-4);">{{ article.published_at | time_tag: format: 'date' }}</div>
    <h1 style="font-family: var(--font-display); font-size: var(--text-4xl); font-weight: 800; margin-bottom: var(--space-6);">{{ article.title }}</h1>
  </div>
  {% if article.image %}
    <div style="margin-bottom: var(--space-8); border-radius: var(--radius-xl); overflow: hidden;">
      {{ article.image | image_url: width: 1200 | image_tag: style: 'width: 100%; height: auto;' }}
    </div>
  {% endif %}
  <div class="rte">
    {{ article.content }}
  </div>
</div>
{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
