<div class="trust-bar section-gap-sm">
  <div class="trust-bar__inner">
    {% for block in section.blocks %}
      <div class="trust-bar__item reveal reveal-delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
        <div class="trust-bar__icon">
          {% case block.settings.icon %}
            {% when 'lock' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0110 0v4"></path></svg>
            {% when 'truck' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            {% when 'shield' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            {% when 'clock' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            {% when 'star' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          {% endcase %}
        </div>
        <div class="trust-bar__content">
          <div class="trust-bar__label">{{ block.settings.title }}</div>
          <div class="trust-bar__desc">{{ block.settings.text }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "lock", "label": "Lock" },
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "clock", "label": "Clock" },
            { "value": "star", "label": "Star" }
          ],
          "default": "lock"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Secure Checkout"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Subheading",
          "default": "100% Encrypted Payments"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "lock", "title": "Secure Checkout", "text": "100% Encrypted Payments" } },
        { "type": "trust_item", "settings": { "icon": "truck", "title": "Fast Shipping", "text": "Worldwide Delivery" } },
        { "type": "trust_item", "settings": { "icon": "shield", "title": "Money Back", "text": "30-Day Guarantee" } },
        { "type": "trust_item", "settings": { "icon": "clock", "title": "24/7 Support", "text": "Dedicated Team" } },
        { "type": "trust_item", "settings": { "icon": "star", "title": "Verified Quality", "text": "Premium Products" } }
      ]
    }
  ]
}
{% endschema %}
