<div class="ugc-section section-gap">
  <div class="container" style="padding-right: 0;"> <!-- Allows carousel to bleed off right edge -->
    <div class="section-header reveal" style="padding-right: var(--container-pad);">
      <div class="section-label">{{ section.settings.eyebrow }}</div>
      <h2 class="section-title">{{ section.settings.title }}</h2>
    </div>

    <div class="ugc-carousel reveal reveal-delay-1">
      {% for block in section.blocks %}
        <div class="ugc-card" {{ block.shopify_attributes }}>
          {% if block.settings.video_url != blank %}
            <video class="ugc-card__video" src="{{ block.settings.video_url }}" loop muted playsinline></video>
          {% else %}
            <div class="ugc-card__thumb">📱</div>
          {% endif %}
          
          <div class="ugc-card__play">
            <svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
          </div>
          
          <div class="ugc-platform">
            {% if block.settings.platform == 'tiktok' %}
              <svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
            {% else %}
              <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            {% endif %}
          </div>

          <div class="ugc-card__info">
            <div class="ugc-card__user">{{ block.settings.username }}</div>
            <div class="ugc-card__handle">@{{ block.settings.handle }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.ugc-card');
    cards.forEach(card => {
      const video = card.querySelector('video');
      if (video) {
        card.addEventListener('mouseenter', () => video.play().catch(e => {}));
        card.addEventListener('mouseleave', () => video.pause());
      }
    });
  });
</script>

{% schema %}
{
  "name": "UGC Videos",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Community"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "See It In Action"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (MP4)"
        },
        {
          "type": "select",
          "id": "platform",
          "label": "Platform Icon",
          "options": [
            { "value": "tiktok", "label": "TikTok" },
            { "value": "instagram", "label": "Instagram" }
          ],
          "default": "tiktok"
        },
        {
          "type": "text",
          "id": "username",
          "label": "Username",
          "default": "Sarah J."
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Handle",
          "default": "sarahj_lifestyle"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Video Carousel",
      "blocks": [
        { "type": "video" },
        { "type": "video", "settings": { "platform": "instagram" } },
        { "type": "video" },
        { "type": "video", "settings": { "platform": "instagram" } }
      ]
    }
  ]
}
{% endschema %}
